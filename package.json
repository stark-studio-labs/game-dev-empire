{
  "name": "tech-empire",
  "version": "0.1.0",
  "description": "Tech Empire — A game dev tycoon simulator by Stark Labs",
  "main": "src/main/main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "dist": "electron-builder --mac dmg",
    "test:e2e": "npx playwright test tests/e2e/"
  },
  "author": "Stark Labs <studio@starklabs.dev>",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "electron": "^35.7.5",
    "electron-builder": "^26.0.0"
  },
  "build": {
    "appId": "dev.starklabs.tech-empire",
    "productName": "Tech Empire",
    "mac": {
      "category": "public.app-category.games",
      "target": [
        "dmg",
        {
          "target": "zip",
          "arch": [
            "arm64"
          ]
        }
      ],
      "identity": null
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    }
  }
}
